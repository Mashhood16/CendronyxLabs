// Translate - apply phrase map first, then handle individual patterns
let translated = 0;
let phraseMatched = 0;

textStrs.forEach(k => {
  const text = en[k].trim();
  
  // Check exact phrase match
  const normText = text.replace(/\.$/, '').replace(/:$/, '').trim();
  if (MAP[normText]) {
    ur[k] = MAP[normText];
    phraseMatched++;
    translated++;
    return;
  }
  if (MAP[text]) {
    ur[k] = MAP[text];
    phraseMatched++;
    translated++;
    return;
  }
  
  // For short labels, keep as English (they're commonly used in Urdu too)
  if (text.length < 30 && !text.includes(' ')) {
    // Single word - keep English
    return;
  }
  
  // For longer texts that don't have a match, keep English for now
  // We'll expand the map
});

fs.writeFileSync('src/locales/roman-urdu/translation.json', JSON.stringify(ur, null, 2));

// Check remaining
const finalSame = Object.keys(en).filter(k => {
  const ev = (en[k] || '').trim();
  const uv = (ur[k] || '').trim();
  return ev && (!uv || uv === ev);
});

const finalText = finalSame.filter(k => !isFormula(en[k]));
console.log('Exact phrase matches:', phraseMatched);
console.log('Total translated this run:', translated);
console.log('Remaining untranslated (total):', finalSame.length);
console.log('Remaining text strings:', finalText.length);
