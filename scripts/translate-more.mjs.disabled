import fs from 'fs';

const en = JSON.parse(fs.readFileSync('src/locales/en/translation.json', 'utf8'));
const ur = JSON.parse(fs.readFileSync('src/locales/roman-urdu/translation.json', 'utf8'));

// Find strings still same as English
const same = Object.keys(en).filter(k => {
  const ev = (en[k] || '').trim();
  const uv = (ur[k] || '').trim();
  return ev && (!uv || uv === ev);
});

// Filter out formula/technical
const isFormula = (t) => {
  if (!t) return true;
  return /[→⇌÷×±∞√∫∑πθρΩωΔ²³⁴⁺⁻°₀₁₂₃₄₅₆₇₈₉≈≠≤≥∂]/.test(t) ||
    /^\d+\.?\d*/.test(t) ||
    /^https?:\/\//.test(t) ||
    /^<[a-z]/.test(t) ||
    /^\$/.test(t) ||
    /^[A-Z][a-z]?\d/.test(t) ||
    /^[a-z]\s*=\s*/.test(t) ||
    t.includes('&&') || t.includes('Math.') ||
    /\\frac|\\sqrt/.test(t) ||
    /^[A-Z0-9._-]+$/.test(t) && t.length < 40;
};

const textStrs = same.filter(k => !isFormula(en[k]));

console.log('Total untranslated:', same.length);
console.log('Text strings to translate:', textStrs.length);

