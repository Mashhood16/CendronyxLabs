  { pattern: 'Tashreeh', replacement: 'Description' },
  { pattern: 'Wazahat', replacement: 'Explanation' },
  { pattern: 'Quwwat', replacement: 'Force' },
  { pattern: 'Baha', replacement: 'Current' },
  { pattern: 'Zaban', replacement: 'Language' },
  { pattern: 'Nap', replacement: 'Size' },
