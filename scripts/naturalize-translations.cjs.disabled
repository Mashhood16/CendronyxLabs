  { pattern: 'Ufqi', replacement: 'Horizontal' },
  { pattern: 'Amoodi', replacement: 'Vertical' },
  { pattern: 'Rokain', replacement: 'Stop' },
  { pattern: 'Kholen', replacement: 'Open' },
  { pattern: 'Bahir Niklein', replacement: 'Exit' },
  { pattern: 'Tawaqquf', replacement: 'Pause' },
  { pattern: 'Jari Rakhein', replacement: 'Continue' },
  { pattern: 'Misaal', replacement: 'Example' },
  { pattern: 'Muntakhab', replacement: 'Selected' },
  { pattern: 'Tahleel', replacement: 'Analysis' },
  { pattern: 'Tahlil', replacement: 'Analysis' },
  { pattern: 'Tashkhees', replacement: 'Diagnosis' },
  { pattern: 'Zawaal', replacement: 'Decay' },
  { pattern: 'Ikhtitami', replacement: 'Final' },
  { pattern: 'Izmitisab', replacement: 'Learning' },
  { pattern: 'Jeewatiyat', replacement: 'Biology' },
  { pattern: 'Hawalajati', replacement: 'Reference' },
