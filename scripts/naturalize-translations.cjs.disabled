  { pattern: 'Mutaghayyiraat', replacement: 'Variables' },
  { pattern: 'Roshnishiddat', replacement: 'Light Intensity' },
  { pattern: 'Tafael', replacement: 'Reaction' },
  { pattern: 'Uzv', replacement: 'Organ' },
  { pattern: 'Hajam', replacement: 'Volume' },
];

// Patterns to detect any remaining unnatural words (fallback safety net)
const RARE_WORD_PATTERNS = [
  /\bTa'amul\b/i, /\bTaamul\b/i,
  /\bTalash\b/i, /\bTawanai\b/i, /\bTawanayi\b/i,
  /\bQuwwat\b/i, /\bDabao\b/i, /\bDabaa\b/i,
  /\bMuzahmat\b/i, /\bTawaddud\b/i,
  /\bTarkeeb\b/i, /\bHalool\b/i,
  /\bAmezish\b/i, /\bMurakkab\b/i, /\bAnsar\b/i,
  /\bSalmiya\b/i, /\bJoher\b/i, /\bMuharrak\b/i,
  /\bPawar\b/i, /\bSharh\b/i, /\bManshoor\b/i,
  /\bBabat\b/i, /\bTashreeh\b/i, /\bMawazna\b/i,
  /\bTareef\b/i, /\bFehrist\b/i, /\bJaiza\b/i,
  /\bTarmeem\b/i, /\bTawaqquf\b/i, /\bMansookh\b/i,
  /\bIntibah\b/i, /\bMaqsood\b/i,
  /\bMushahida\b/i, /\bNateeja\b/i, /\bMufroza\b/i,
  /\bKasaafat\b/i, /\bWazahat\b/i, /\bUnwan\b/i,
  /\bPaimaish\b/i, /\bTajziya\b/i, /\bTajzia\b/i,
  /\bHalat\b/i, /\bTaraqqi\b/i,
  /\bKhabardar\b/i, /\bKhata\b/i, /\bNatija\b/i,
  /\bNumber\b/i, /\bMehfooz\b/i,
  /\bShamil Karein\b/i, /\bTasdeeq\b/i, /\bPesh\b/i,
  /\bBahir Niklein\b/i, /\bMadad\b/i, /\bIshara\b/i,
  /\bSatah\b/i, /\bUfqi\b/i, /\bAmoodi\b/i,
  /\bAsbaaq\b/i, /\bMazameen\b/i,
  /\bMuntakhab\b/i, /\bTahleel\b/i, /\bTahlil\b/i,
  /\bTashkhees\b/i, /\bZawaal\b/i,
  /\bIkhtitami\b/i, /\bIzmitisab\b/i,
  /\bJeewatiyat\b/i, /\bHawalajati\b/i,
  /\bKhusoosiyaat\b/i, /\bMasawatain\b/i,
  /\bMutaghayyiraat\b/i, /\bRoshnishiddat\b/i,
  /\bTafael\b/i, /\bUzv\b/i,
  /\bHajam\b/i,
];

function isNatural(text) {
  if (!text) return true;
  for (const pattern of RARE_WORD_PATTERNS) {
    if (pattern.test(text)) return false;
  }
  return true;
}

// Apply replacements
let wordReplacements = 0;
let revertedToEnglish = 0;

Object.keys(en).forEach(k => {
  const ev = (en[k] || '').trim();
  const uv = (ur[k] || '').trim();
  if (!ev || !uv || uv === ev) return;
  
  let updated = uv;
  const sorted = [...REPLACEMENTS].sort((a, b) => b.pattern.length - a.pattern.length);
  for (const { pattern, replacement } of sorted) {
    const regex = new RegExp(pattern.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g');
    const before = updated;
    updated = updated.replace(regex, replacement);
    if (updated !== before) wordReplacements++;
  }
  
  if (!isNatural(updated)) {
    ur[k] = ev;
    revertedToEnglish++;
  } else {
    ur[k] = updated;
  }
});

fs.writeFileSync(UR_FILE, JSON.stringify(ur, null, 2));

console.log('Word replacements:', wordReplacements);
console.log('Reverted to English:', revertedToEnglish);

const translated = Object.keys(en).filter(k => {
  const ev = (en[k] || '').trim();
  const uv = (ur[k] || '').trim();
  return ev && uv && uv !== ev;
});
console.log('Total translations:', translated.length);

let remaining = 0;
translated.forEach(k => { if (!isNatural(ur[k])) remaining++; });
console.log('Remaining unnatural:', remaining);
