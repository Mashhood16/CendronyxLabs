const fs = require('fs');
const EN_FILE = 'src/locales/en/translation.json';
const UR_FILE = 'src/locales/roman-urdu/translation.json';
const en = JSON.parse(fs.readFileSync(EN_FILE, 'utf8'));
const ur = JSON.parse(fs.readFileSync(UR_FILE, 'utf8'));

// RARE/FORMAL Urdu words that should be REPLACED with natural alternatives
const REPLACEMENTS = [
  { pattern: 'Asbaaq', replacement: 'Modules' },
  { pattern: 'Mazameen', replacement: 'Subjects' },
  { pattern: 'Unwan', replacement: 'Title' },
  { pattern: 'Khatam Karein', replacement: 'Delete' },
  { pattern: 'Mehfooz Karein', replacement: 'Save' },
  { pattern: 'Tarmeem Karein', replacement: 'Edit' },
  { pattern: 'Tasdeeq Karein', replacement: 'Confirm' },
  { pattern: 'Pesh Karein', replacement: 'Submit' },
  { pattern: 'Mansookh Karein', replacement: 'Cancel' },
  { pattern: 'Band Karein', replacement: 'Close' },
  { pattern: 'Janch Karein', replacement: 'Check' },
  { pattern: 'Janch', replacement: 'Check' },
  { pattern: 'Dobara Set Karein', replacement: 'Reset' },
  { pattern: 'Shamil Karein', replacement: 'Add' },
  { pattern: 'Talash Karein', replacement: 'Search' },
  { pattern: 'Record Karein', replacement: 'Record' },
  { pattern: 'Hisab Karein', replacement: 'Calculate' },
  { pattern: 'Pehchan Karein', replacement: 'Identify' },
  { pattern: 'Tajurba', replacement: 'Experiment' },
