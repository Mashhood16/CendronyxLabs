// Also handle common Urdu prefixes/suffixes
const commonPrefixes = [
  ['نا', 'na-'], // ناقابل -> na-qabil
  ['لا', 'la-'], // لازوال -> la-zawal
  ['بے', 'be-'], // بےحد -> be-had
  ['با', 'ba-'], // باعزت -> ba-izzat
];

/**
 * Check if a string contains Urdu/Arabic script
 */
function hasUrduScript(text) {
  return /[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]/.test(text);
}

/**
 * Check if a string is a formula/equation that should be preserved
 */
function isFormula(text) {
  // Chemical formulas, math equations, code
  const formulaPatterns = [
    /[→⇌÷×±∞√∫∑πθρΩω²³⁴⁺⁻°]/,
    /^[A-Z][a-z]?\d/, // H2O, CO2 etc
    /[A-Z]{2,}\(/, // NaOH( etc
    /\\frac|\\sqrt|\\sum|\\int/,
    /[=<>]\s*[-+]?\d+\.?\d*/,
    /^[A-Z][a-z]?\d?[A-Z]/, // NaCl, KMnO4
    /\([sglaq]+\b/, // (s), (g), (aq)
    /\b\d+\s*[+×÷]\s*\d+/,
    /\b[A-Z][a-z]?\d*[+×÷]/,
    /[≈±≥≤]/,
    /→|⇌/,
  ];
  return formulaPatterns.some(p => p.test(text));
}

/**
 * Check if a string has mostly symbols/numbers (should NOT be translated)
 */
function isMostlySymbolic(text) {
  const clean = text.replace(/\s+/g, '');
  if (clean.length < 3) return false;
  const letters = clean.replace(/[^a-zA-Z]/g, '').length;
  return letters / clean.length < 0.3;
}

/**
 * Basic Urdu to Roman Urdu transliteration for a full text
 */
function transliterateUrduToRoman(text) {
  if (!text || !hasUrduScript(text)) return text;
  
  let result = text;
  
  // Replace known words (longer matches first to avoid partial replacements)
  const sortedEntries = Object.entries(urduToRoman).sort((a, b) => b[0].length - a[0].length);
  for (const [urdu, roman] of sortedEntries) {
    // Escape special regex characters in Urdu text
    const escaped = urdu.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    result = result.replace(new RegExp(escaped, 'g'), roman);
  }
  
  // Clean up any remaining Urdu characters
  result = result.replace(/[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]/g, '');
  
  // Clean up double spaces
  result = result.replace(/\s+/g, ' ').trim();
  
  return result;
}

// Track fixes
let urduFixed = 0;
let formulaFixed = 0;
let skipped = 0;
let errors = [];

const fixed = {};

Object.entries(ur).forEach(([key, val]) => {
  if (!val || !val.trim()) {
    fixed[key] = val;
    return;
  }
  
  const original = en[key] || '';
  let newVal = val;
  
  // Issue 1: Fix Urdu script to Roman Urdu
  if (hasUrduScript(val)) {
    newVal = transliterateUrduToRoman(val);
    if (newVal !== val) {
      urduFixed++;
      console.log(`URDU FIXED [${key}]: ${val.substring(0, 60)} → ${newVal.substring(0, 60)}`);
    }
  }
  
  // Issue 2: Fix corrupted formulas
  if (original && isFormula(original) && original !== newVal) {
    // Revert to original English if the translation modified formula content
    const hasMathSymbols = /[→⇌÷×±∞√∫∑πθρΩω²³⁴⁺⁻°=<>]/.test(original);
    const hasChemFormula = /^[A-Z][a-z]?\d/.test(original);
    
    if (hasMathSymbols || hasChemFormula || isMostlySymbolic(original)) {
      console.log(`FORMULA FIXED [${key}]: ${newVal.substring(0, 60)} → ${original.substring(0, 60)}`);
      newVal = original;
      formulaFixed++;
    }
  }
  
  fixed[key] = newVal;
});

// Also check for translations that should be their English original
// (e.g., strings that are purely formulas, code, or protected words)
Object.entries(en).forEach(([key, val]) => {
  if (!fixed[key] && val) {
    // If not yet translated, check if it should be auto-preserved
    if (isFormula(val) && isMostlySymbolic(val)) {
      fixed[key] = val;
      skipped++;
      if (skipped <= 5) console.log(`AUTO-PRESERVED: ${key} = ${val.substring(0, 80)}`);
    }
  }
});

// Write fixed file
const outputPath = 'src/locales/roman-urdu/translation.json';
fs.writeFileSync(outputPath, JSON.stringify(fixed, null, 2));

console.log('\n=== FIX SUMMARY ===');
console.log(`Urdu → Roman conversions: ${urduFixed}`);
console.log(`Formulas reverted: ${formulaFixed}`);
console.log(`Auto-preserved formulas: ${skipped}`);
console.log(`Total entries: ${Object.keys(fixed).length}`);
