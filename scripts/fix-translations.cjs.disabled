/**
 * Fix Script for Roman Urdu Translations
 * 
 * This script:
 * 1. Converts Urdu script (Arabic characters) to Roman Urdu (English alphabet)
 * 2. Reverts corrupted formulas back to their English originals
 * 3. Provides a safety filter for future translations
 * 
 * Usage: node scripts/fix-translations.cjs
 */

const fs = require('fs');
const path = require('path');

const EN_FILE = 'src/locales/en/translation.json';
const UR_FILE = 'src/locales/roman-urdu/translation.json';
const PROTECTED_FILE = 'scripts/protected-words.json';

const en = JSON.parse(fs.readFileSync(EN_FILE, 'utf8'));
const ur = JSON.parse(fs.readFileSync(UR_FILE, 'utf8'));
const protectedWords = new Set(JSON.parse(fs.readFileSync(PROTECTED_FILE, 'utf8')).map(w => w.toLowerCase()));

