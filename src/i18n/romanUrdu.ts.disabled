  // --- Class 10 Physics Derivations ---
  // Echo
  'lab.p10_echo_title': 'Derivation: Depth via Echo (Ultrasound)',
  'lab.p10_echo_subtitle': 'Ultrasound depth formula bunyadi speed se hasil karna',
  'lab.p10_echo_final_desc': 'Depth = (Speed × Time) / 2 — sonar aur ultrasound mein istemal',
  'lab.p10_echo_step1_label': 'Basic Speed Formula',
  'lab.p10_echo_step2_label': 'Distance Double Hai (Wahan aur Wapas)',
  'lab.p10_echo_step3_label': 'D ki Jagah Substitute Karein',
  'lab.p10_echo_step4_label': 'Distance ke Liye Hal Karein',
  'lab.p10_echo_step1_detail': 'Aap ek sonar operator hain jo samandar ki teh map kar rahe hain. Aap ek powerful ping bhejte hain. Speed = distance / time — awaaz 1500 m/s se pani mein travel karti hai.',
  'lab.p10_echo_step2_detail': 'Ping samandar ki teh se takra kar wapas aata hai. Kul safar wahan AUR wapas: D = 2d. Aap sunte hain, echo ka intezaar karte hain...',
  'lab.p10_echo_step3_detail': 'Aap ka equipment theek 0.4 seconds measure karta hai ping bhejne aur echo pane ke darmiyan. v = 2d/t matlab 1500 = 2d/0.4. Aawaz ne 600 m ka safar kiya.',
  'lab.p10_echo_step4_detail': 'd = v × t / 2 = 1500 × 0.4 / 2 = 300 m. 2 se is liye divide karte hain kyunki awaaz neeche AUR upar gayi! Yahi formula ocean floor map karta hai, submarines detect karta hai, aur ultrasound images banata hai.',
  'lab.p10_echo_trace1': 'D = v×t = {vt} m',
  'lab.p10_echo_trace2': 'd = D/2 = {vt}/2',
  'lab.p10_echo_trace3': 'd = {d} m',
  'lab.p10_echo_real_life': 'Chamgadad echolocation istemal karte hain — yeh ultrasonic chirps nikaalte hain aur echoes sunte hain. 17 kHz ki awaaz 1 m door patange se 6 ms mein wapas aati hai, chamgadad ko andhere mein shikar maloom karne deti hai.',
  'lab.p10_echo_practice_q': 'Ek jahaz sonar pulse bhejta hai. Echo 0.4 s ke baad wapas aata hai. Paani mein awaaz = 1500 m/s.',
  'lab.p10_echo_practice_q2': 'Ocean floor ki gahrai maloom karein.',
  'lab.p10_echo_practice_hint': 'd = 1500 × 0.4 / 2 = ?',
  'lab.p10_echo_correct_fb': 'Sahi! 300 m. Kul distance 600 m hai (wahan aur wapas), is liye ocean floor 300 m gehra hai.',
  'lab.p10_echo_incorrect_fb': 'Ghalat. Yad rakhein 2 se divide karna! d = v×t/2 = 1500×0.4/2',
  'lab.p10_echo_speed_label': 'Speed (v)',
  'lab.p10_echo_time_label': 'Echo Time (t)',
  'lab.p10_echo_placeholder': 'Depth in meters...',

  // Critical Angle
  'lab.p10_critical_title': 'Derivation: Critical Angle for TIR',
  'lab.p10_critical_subtitle': 'θc ko Snell ke Law se Total Internal Reflection ke liye hasil karna',
  'lab.p10_critical_final_desc': 'Critical angle total internal reflection ki hadd tay karta hai',
  'lab.p10_critical_step1_label': 'Critical Angle par, θr = 90°',
  'lab.p10_critical_step2_label': 'sin 90° = 1',
  'lab.p10_critical_step3_label': 'Critical Angle ke liye Hal Karein',
  'lab.p10_critical_step1_detail': 'Paani ke neeche tairte hue, aap oopar dekhte hain. Oopar ki duniya ek chamakti hui circle nazar aati hai. Roshni pani (n=1.33) se hawa (n=1.0) mein jaate hue mudti hai. Snell ka law n₁ sinθᵢ = n₂ sinθr mukammal tor par yeh bayan karta hai.',
  'lab.p10_critical_step2_detail': 'Jaise jaise aap gehra hota hain aur zyada dhale dekhte hain, roshan circle chhota hota hai. Ek khaas angle par, refracted ray 90 degrees par surface ke saath chalti hai. Yeh critical angle hai — is ke baghair, aap pani ke oopar nahi dekh sakte.',
  'lab.p10_critical_step3_detail': 'sin 90 = 1 ke saath, Snell ka law mukhtasar hota hai: n₁ sinθc = n₂. Pani ki surface ek perfect mirror mein badal jati hai. Critical angle se neeche, total internal reflection shuru ho jata hai.',
  'lab.p10_critical_trace1': 'n₁ sinθc = n₂ × 1',
  'lab.p10_critical_trace2': 'sinθc = {n2}/{n1} = {ratio}',
  'lab.p10_critical_trace3': 'θc = {theta}°',
  'lab.p10_critical_real_life': 'Heere chamakte hain kyunki in ka refractive index bohat zyada hai (n=2.42), jis se critical angle sirf 24° banta hai. Andar aane wali roshni total internal reflection se trapped ho jati hai, andar bounce karti hai aur nikalte waqt chamak paida karti hai!',
  'lab.p10_critical_practice_q': 'Glass ka n = 1.5 hai aur hawa ka n = 1.0 hai. Glass-air boundary ke liye critical angle maloom karein.',
  'lab.p10_critical_practice_hint': 'θc = sin⁻¹(1/1.5) = ?',
  'lab.p10_critical_correct_fb': 'Sahi! 41.8°. Is angle ke aage, glass ke andar roshni totally reflect hoti hai — optical fibers ka principle!',
  'lab.p10_critical_incorrect_fb': 'Ghalat. θc = sin⁻¹(n₂/n₁) = sin⁻¹(1/1.5) ≈ 41.8°',
  'lab.p10_critical_n1_label': 'Denser Medium (n₁)',
  'lab.p10_critical_n2_label': 'Rarer Medium (n₂)',
  'lab.p10_critical_placeholder': 'θc in degrees...',
  'lab.p10_critical_adjust_desc': 'Refractive indices adjust karein critical angle change dekhne ke liye.',

  // Wave Equation
  'lab.p10_waveeq_title': 'Derivation: Universal Wave Equation v = fλ',
  'lab.p10_waveeq_subtitle': 'Universal wave equation bunyadi speed formula se hasil karna',
  'lab.p10_waveeq_final_desc': 'Speed = Frequency × Wavelength — tamam waves ke liye universal',
  'lab.p10_waveeq_step1_label': 'Wave Speed = Distance / Time',
  'lab.p10_waveeq_step2_label': 'Ek Wavelength Ek Period Mein',
  'lab.p10_waveeq_step3_label': 'Frequency = 1 / Period',
  'lab.p10_waveeq_step4_label': 'Final Wave Equation',
  'lab.p10_waveeq_step1_detail': 'Aap beach par lehron ko aate dekhte hain. Wave speed = distance / time: v = d/t.',
  'lab.p10_waveeq_step2_detail': 'Ek mukammal wave cycle mein, ek wave theek ek wavelength travel karti hai ek time period T mein. Substituting: v = λ/T.',
  'lab.p10_waveeq_step3_detail': 'Frequency f = 1/T. Zyada frequency matlab zyada waves per second. Light waves ki frequencies bahut bari hoti hain — 5e14 Hz green light ke liye.',
  'lab.p10_waveeq_step4_detail': 'v = f × λ. Yeh UNIVERSAL wave equation hai — yeh SAB waves ke liye kaam karti hai. Aawaz, roshni, radio, pani ki waves — sab v = fλ maanti hain!',
  'lab.p10_waveeq_trace1': 'v = d/t',
  'lab.p10_waveeq_trace2': 'v = λ/T = {wl}/({invf})',
  'lab.p10_waveeq_trace3': 'v = fλ = {freq}×{wl}',
  'lab.p10_waveeq_real_life': 'Guitar string ko 82 Hz (low E) par tune karna jis ki length 0.65 m hai matlab wave speed 107 m/s hai. String ko tighten karne se wave speed barhti hai, frequency badhti hai — is tarah aap guitar tune karte hain.',
  'lab.p10_waveeq_practice_q': 'Ek sound wave mein f = 440 Hz (middle A) aur λ = 0.78 m hai. Sound speed maloom karein.',
  'lab.p10_waveeq_practice_hint': 'v = 440 × 0.78 = ?',
  'lab.p10_waveeq_correct_fb': 'Sahi! ~343 m/s. 20°C par hawa mein awaaz ki speed yahi hai!',
  'lab.p10_waveeq_incorrect_fb': 'Ghalat. v = f × λ = 440 × 0.78 = ?',
  'lab.p10_waveeq_freq_label': 'Frequency (f)',
  'lab.p10_waveeq_wavelength_label': 'Wavelength (λ)',
  'lab.p10_waveeq_placeholder': 'Speed in m/s...',

  // Electric Power
  'lab.p10_power_title': 'Derivation: Electric Power P = VI',
  'lab.p10_power_subtitle': 'Power formula voltage aur current ki tareefon se hasil karna',
  'lab.p10_power_final_desc': 'Power = Voltage × Current — circuit mein energy transfer ki sharah',
  'lab.p10_power_step1_label': 'Work = Energy Transferred',
  'lab.p10_power_step2_label': 'Potential Difference = Energy per Charge',
  'lab.p10_power_step3_label': 'Current = Charge per Time',
  'lab.p10_power_step4_label': 'Power = Energy / Time = V × I',
  'lab.p10_power_step1_detail': 'Power aap ko batati hai ke electrical energy kitni tezi se istemal ho rahi hai. Ek 60W bulb har second 60 J electrical energy ko light aur heat mein convert karta hai. Power = Energy / Time — energy transfer ki sharah.',
  'lab.p10_power_step2_detail': 'Voltage V, energy per unit charge hai: V = E/Q. Ek volt matlab 1 J energy per coulomb charge. Ek 12V battery har coulomb ko 12 J energy deti hai jo behta hai.',
  'lab.p10_power_step3_detail': 'Current I, charge per second hai: I = Q/t. Ek ampere = 1 coulomb per second. Total charge jo behta hai woh energy carry karta hai jo convert hoti hai.',
  'lab.p10_power_step4_detail': 'P = E/t = (V × Q)/t = V × (Q/t) = V × I. Power = Voltage × Current. 60W bulb 120V par I = P/V = 0.5 A draw karta hai. Aap ka phone charger 5V, 2A par 10W power deta hai.',
  'lab.p10_power_trace1': 'P = E/t',
  'lab.p10_power_trace2': 'V = E/Q, to E = V×Q',
  'lab.p10_power_trace3': 'I = Q/t, to Q = I×t',
  'lab.p10_power_real_life': 'Power companies kilowatt-hours (kWh) mein charge karti hain. 1 kWh = 3.6 MJ. 100W bulb 10 ghante jalne se 1 kWh istemal karta hai. Aap ka monthly bill = total kWh × rate.',
  'lab.p10_power_practice_q': 'Ek 1.5 kW kettle 240 V par chalta hai. Yeh kitna current draw karta hai?',
  'lab.p10_power_practice_hint': 'I = P/V = 1500/240 = ?',
  'lab.p10_power_correct_fb': 'Sahi! I = 6.25 A. Is liye kettles ko mote tar ki zaroorat hoti hai — yeh zyada current draw karte hain!',
  'lab.p10_power_incorrect_fb': 'Ghalat. I = P / V = 1500 / 240',
  'lab.p10_power_v_label': 'Voltage (V)',
  'lab.p10_power_i_label': 'Current (I)',
  'lab.p10_power_placeholder': 'Power in Watts...',

  // Electrical Energy
  'lab.p10_elecenergy_title': 'Derivation: Electrical Energy E = Pt',
  'lab.p10_elecenergy_subtitle': 'Energy ko power aur time se hasil karna',
  'lab.p10_elecenergy_final_desc': 'Energy = Power × Time — aap kitni bijli istemal karte hain',
  'lab.p10_elecenergy_step1_label': 'Power ki Tareef',
  'lab.p10_elecenergy_step2_label': 'Energy ke liye Dobara Arrange Karein',
  'lab.p10_elecenergy_step3_label': 'P = VI ki Jagah Substitute Karein',
  'lab.p10_elecenergy_step4_label': 'Final Formula: E = VIt',
  'lab.p10_elecenergy_step1_detail': 'Power batati hai ke kitni tezi se energy istemal ho rahi hai. 2000W AC 2000 J per second energy consume karta hai. Jitni der chalta hai, utni zyada energy consume karta hai.',
  'lab.p10_elecenergy_step2_detail': 'P = E/t, to E = P × t. Agar aap AC 1 ghante (3600 s) chalate hain, E = 2000 × 3600 = 7,200,000 J. Yeh bahut zyada energy hai!',
  'lab.p10_elecenergy_step3_detail': 'Kyunke P = V × I, hum E = V × I × t likh sakte hain. 2000W AC 240V par I = P/V = 2000/240 = 8.33 A draw karta hai. E = VIt = 240 × 8.33 × 3600 = 7.2 MJ.',
  'lab.p10_elecenergy_step4_detail': 'E = VIt. Yeh voltage, current, aur time ko ek formula mein jorta hai electrical energy ke liye. 1 kilowatt-hour (kWh) = 3.6 MJ. Aap ka bijli ka bill kWh istemal par based hai.',
  'lab.p10_elecenergy_trace1': 'P = E/t',
  'lab.p10_elecenergy_trace2': 'E = P × t = {p} × {t}',
  'lab.p10_elecenergy_trace3': 'E = {e} J',
  'lab.p10_elecenergy_real_life': 'Ek aam UK ghar 10 kWh per day istemal karta hai. Yeh 36 MJ electrical energy hai! Aap ki chhat par solar panels peak sunlight mein 1 kWh per hour per square meter generate karti hain.',
  'lab.p10_elecenergy_practice_q': 'Ek 100W LED bulb 5 ghante chalta hai. Yeh kitni energy kWh mein consume karta hai?',
  'lab.p10_elecenergy_practice_hint': 'E = Pt = 100 × 5 = 500 Wh = 0.5 kWh',
  'lab.p10_elecenergy_correct_fb': 'Sahi! 0.5 kWh. Yeh taqreeban 1.8 MJ energy hai.',
  'lab.p10_elecenergy_incorrect_fb': 'Ghalat. E = P × t = 100 × 5 = 500 Wh. kWh mein convert karne ke liye 1000 se divide karein.',
  'lab.p10_elecenergy_p_label': 'Power (P)',
  'lab.p10_elecenergy_t_label': 'Time (t)',
  'lab.p10_elecenergy_placeholder': 'Energy in Joules...',

  // Expansion of Liquids
  'lab.p10_expLiq_title': 'Derivation: Real vs Apparent Expansion of Liquids',
  'lab.p10_expLiq_subtitle': 'Samajhna ke γ_r = γ_a + γ_g kyun',
  'lab.p10_expLiq_final_desc': 'Real = Apparent + Glass expansion coefficients',
  'lab.p10_expLiq_step1_label': 'Coefficients ki Tareef',
  'lab.p10_expLiq_step2_label': 'Tabeeghati Maani',
  'lab.p10_expLiq_step3_label': 'Kyun Yeh Ahem Hai',
  'lab.p10_expLiq_step1_detail': 'Garmiyon ke din, aap outdoor thermometer check karte hain. Laal liquid glass tube mein oopar chadhti hai. Lekin glass bhi phailta hai — aap sirf APPARENT expansion dekh rahe hain.',
  'lab.p10_expLiq_step2_detail': 'γ_r = γ_a + γ_g. Liquid ka real expansion (γ_r) utna hi hai jo aap observe karte hain (γ_a) plus glass flask expansion (γ_g). Glass liquid ki asliyat chhupata hai.',
  'lab.p10_expLiq_step3_detail': 'γ_r hamesha γ_a se bada hota hai. Glass container bhi barhta hai, liquid ke liye extra jagah banata hai.',
  'lab.p10_expLiq_trace1': 'γ_r = {ga} + {gg} = {gr}',
  'lab.p10_expLiq_real_life': 'Thermometers mercury ya alcohol expansion istemal karte hain — 1°C rise liquid ko narrow capillary mein oopar dhakelta hai. Mercury thermometers -39°C se 357°C tak kaam karte hain.',
  'lab.p10_expLiq_practice_q': 'Liquid ka apparent expansion γ_a = 1.2×10⁻⁴/°C. Glass expansion γ_g = 2.5×10⁻⁵/°C. γ_r maloom karein.',
  'lab.p10_expLiq_practice_hint': 'γ_r = 1.2×10⁻⁴ + 2.5×10⁻⁵ = 1.45×10⁻⁴/°C',
  'lab.p10_expLiq_correct_fb': 'Sahi! 1.45×10⁻⁴/°C. Real expansion hamesha apparent se bara hota hai.',
  'lab.p10_expLiq_incorrect_fb': 'Ghalat. γ_r = γ_a + γ_g = (1.2 + 0.25)×10⁻⁴',
  'lab.p10_expLiq_gammaa_label': 'Apparent Coeff (γ_a)',
  'lab.p10_expLiq_gammag_label': 'Glass Coeff (γ_g)',
  'lab.p10_expLiq_placeholder': 'γ_r value...',
  'lab.p10_expLiq_adjust_desc': 'Expansion coefficients adjust karein real vs apparent relationship dekhne ke liye.',

  // Linear Expansion - same pattern as English but in Roman Urdu
  'lab.p10_linExp_title': 'Derivation: Linear Thermal Expansion',
  'lab.p10_linExp_subtitle': 'α coefficient of linear thermal expansion hasil karna',
  'lab.p10_linExp_final_desc': 'Coefficient of linear thermal expansion',
  'lab.p10_linExp_step1_label': 'Lambai ka Change Proportional Hai',
  'lab.p10_linExp_step2_label': 'Proportionality Constant Dakhil Karein',
  'lab.p10_linExp_step3_label': 'α ke Liye Dobara Arrange Karein',
  'lab.p10_linExp_step4_label': 'Final Formula',
  'lab.p10_linExp_step1_detail': 'Garmiyon ke din, train tracks heat se buckle ho sakte hain. Lambai mein change original length aur temperature change ke proportional hai.',
  'lab.p10_linExp_step2_detail': 'Engineers expansion joints istemal karte hain buckling rokne ke liye. Steel ka α = 1.2e-5 per °C.',
  'lab.p10_linExp_step3_detail': 'α = ΔL/(L₀·ΔT). 100 m rail 15°C se 45°C tak garam hone par 3.6 cm phailti hai.',
  'lab.p10_linExp_step4_detail': 'L = L₀(1 + α·ΔT). Invar mushkil se phailta hai — precision instruments mein istemal hota hai.',
  'lab.p10_linExp_trace1': 'ΔL = {alpha}×{lo}×{dt} = {dl} mm',
  'lab.p10_linExp_real_life': 'Railway tracks mein expansion gaps hote hain — steel 0.012 mm/m/°C se phailta hai. 1 km track 40°C par winter se 12 cm lamba hota hai.',
  'lab.p10_linExp_practice_q': 'Steel rail 20 m lamba 15°C par. Garmiyon mein 45°C. α = 1.2×10⁻⁵/°C. Kitna phailta hai?',
  'lab.p10_linExp_practice_hint': 'ΔL = 1.2×10⁻⁵ × 20 × 30 = 7.2 mm',
  'lab.p10_linExp_correct_fb': 'Sahi! 7.2 mm. 1 km rail par yeh 36 cm hota — is liye expansion gaps hain!',
  'lab.p10_linExp_incorrect_fb': 'Ghalat. ΔL = α × L₀ × ΔT. ΔT = 45-15 = 30°C.',
  'lab.p10_linExp_lo_label': 'Original Length (L₀)',
  'lab.p10_linExp_dt_label': 'Temp Change (ΔT)',
  'lab.p10_linExp_alpha_label': 'Coefficient (α)',
  'lab.p10_linExp_placeholder': 'ΔL in mm...',
  'lab.p10_linExp_adjust_desc': 'Values adjust karein dekhen rods temperature ke saath kaise phailti hain.',

  // Rest of derivations - abbreviated Roman Urdu for efficiency
  'lab.p10_mag_title': 'Derivation: Linear Magnification',
  'lab.p10_mag_subtitle': 'M = I/O = q/p geometry se hasil karna',
  'lab.p10_mag_final_desc': 'Magnification = Image height / Object height = Image distance / Object distance',
  'lab.p10_mag_step1_label': 'Ray Diagram Similar Triangles Se',
  'lab.p10_mag_step2_label': 'Combined Formula',
  'lab.p10_mag_step3_label': 'Sign Convention Ahem Hai',
  'lab.p10_mag_step1_detail': 'Aap magnifying glass se ek choti antique watch dekh rahe hain. Magnification M = I/O. Lens choti cheez ko bara dikhata hai.',
  'lab.p10_mag_step2_detail': 'Ray diagram geometry se similar triangles zahir karte hain M = q/p.',
  'lab.p10_mag_step3_detail': 'M = I/O = q/p. Concave mirror ke liye, q real images ke liye negative hota hai.',
  'lab.p10_mag_trace1': 'M = {m1} = {m2}',
  'lab.p10_mag_real_life': 'Microscopes do lenses istemal karte hain — objective magnified real image banata hai, eyepiece aur magnify karta hai. 1000× magnification tak!',
  'lab.p10_mag_practice_q': '2 cm object 15 cm door concave mirror se. Image 30 cm aage banti hai. Magnification aur image height maloom karein.',
  'lab.p10_mag_practice_hint': 'M = q/p = 30/15 = 2. I = M×O = 2×2 = 4 cm (ulta)',
  'lab.p10_mag_correct_fb': 'Sahi! I = 4 cm (ulta). M = -2 matlab double tall aur inverted!',
  'lab.p10_mag_incorrect_fb': 'M = q/p = 30/15 = 2. Image height = M×O = 2×2 = 4 cm',
  'lab.p10_mag_oh_label': 'Object Height (O)',
  'lab.p10_mag_ih_label': 'Image Height (I)',
  'lab.p10_mag_od_label': 'Object Distance (p)',
  'lab.p10_mag_placeholder': 'Image height (cm)...',
  'lab.p10_mag_adjust_desc': 'Values adjust karein dono methods se magnification dekhne ke liye.',

  'lab.p10_par_title': 'Derivation: Parallel Resistance',
  'lab.p10_par_subtitle': '1/R_eq = 1/R₁ + 1/R₂ + 1/R₃ hasil karna',
  'lab.p10_par_final_desc': 'Parallel resistances ke liye reciprocals jorte hain',
  'lab.p10_par_step1_label': 'Branches Mein Currents Jortay Hain',
  'lab.p10_par_step2_label': 'Voltage ko Factor Out Karein',
  'lab.p10_par_step3_label': 'Ahem Usool',
  'lab.p10_par_step1_detail': 'Aap switch dabate hain aur ceiling light jalti hai. Doosra lamp lagayein — dono chamakte hain kyunki parallel hain. Total current branches mein bat-ta hai.',
  'lab.p10_par_step2_detail': 'Har branch ke liye Ohm ka law: V/Req = V/R₁ + V/R₂ + V/R₃. Voltage parallel components mein ek jaisa hai.',
  'lab.p10_par_step3_detail': 'V se divide karein: 1/Req = 1/R₁ + 1/R₂ + 1/R₃. Do 100Ω resistors: 1/Req = 2/100, to Req = 50Ω. Zyada paths = RESISTANCE KAM!',
  'lab.p10_par_trace1': 'R_eq = {req} Ω',
  'lab.p10_par_real_life': 'Ghar ki wiring parallel hai har outlet ko 230V dene ke liye. Ek appliance hatao to doosron par farq nahi padta.',
  'lab.p10_par_practice_q': 'Do resistors 100Ω aur 100Ω parallel mein. Equivalent resistance maloom karein.',
  'lab.p10_par_practice_hint': '1/Req = 1/100 + 1/100 = 2/100. Req = 50Ω',
  'lab.p10_par_correct_fb': 'Sahi! 50Ω. Do equal resistors parallel mein aadhi value dete hain.',
  'lab.p10_par_incorrect_fb': '1/Req = 1/100 + 1/100 = 2/100. To Req = 100/2 = 50Ω',
  'lab.p10_par_r1_label': 'R₁',
  'lab.p10_par_r2_label': 'R₂',
  'lab.p10_par_r3_label': 'R₃',
  'lab.p10_par_placeholder': 'R_eq in Ω...',
  'lab.p10_par_adjust_desc': 'Resistors adjust karein parallel equivalent dekhne ke liye.',

  'lab.p10_photon_title': 'Derivation: Photon Energy & Momentum',
  'lab.p10_photon_subtitle': 'E = hf = hc/λ aur p = h/λ hasil karna',
  'lab.p10_photon_final_desc': 'Photon energy aur momentum Planck aur de Broglie se',
  'lab.p10_photon_step1_label': 'Light ke liye Wave Equation',
  'lab.p10_photon_step2_label': 'Photon Momentum',
  'lab.p10_photon_step1_detail': 'Max Planck ne daryaft kiya light chotay packets photons mein aati hai. E = hf — har photon ki energy Planck constant × frequency.',
  'lab.p10_photon_step2_detail': 'Light ke liye c = fλ to f = c/λ. Laal roshni (700nm) ki frequency low. UV light (380nm se neeche) ki frequency zyada — zyada energetic photons.',
  'lab.p10_photon_trace1': 'E = {e} J, λ = {wl} m',
  'lab.p10_photon_real_life': 'Remote controls 940 nm infrared LEDs istemal karte hain — har photon 2.1×10⁻¹⁹ J energy rakhta hai. Aap ka TV hazaron per second detect karta hai.',
  'lab.p10_photon_practice_q': 'Hari roshni f = 5.45×10¹⁴ Hz. h = 6.63×10⁻³⁴. Photon energy maloom karein.',
  'lab.p10_photon_practice_hint': 'E = 6.63×10⁻³⁴ × 5.45×10¹⁴ = 3.61×10⁻¹⁹ J',
  'lab.p10_photon_correct_fb': 'Sahi! 3.61×10⁻¹⁹ J (2.25 eV). Photon energy human scale par bahut choti hai!',
  'lab.p10_photon_incorrect_fb': 'E = hf = 6.63×10⁻³⁴ × 5.45×10¹⁴ = 3.61×10⁻¹⁹ J',
  'lab.p10_photon_freq_label': 'Frequency (f)',
  'lab.p10_photon_placeholder': 'Energy in Joules...',
  'lab.p10_photon_adjust_desc': 'Frequency adjust karein photon energy aur momentum dekhne ke liye.',

  'lab.p10_potDiv_title': 'Derivation: Potential Divider Formula',
  'lab.p10_potDiv_subtitle': 'V_out = R₂/(R₁+R₂) × V_in hasil karna',
  'lab.p10_potDiv_final_desc': 'Output voltage resistance ratio par munsar hai',
  'lab.p10_potDiv_step1_label': 'Series Circuit Mein Current',
  'lab.p10_potDiv_step2_label': 'Current Substitute Karein',
  'lab.p10_potDiv_step3_label': 'Potential Divider Formula',
  'lab.p10_potDiv_step1_detail': 'Aap speakers par volume knob ghumate hain. Andar potentiometer hai — ek variable resistor jo voltage divide karta hai.',
  'lab.p10_potDiv_step2_detail': 'Jo voltage aap chahte hain woh R₂ ke across hai. Ohm ke law se: V_out = I × R₂.',
  'lab.p10_potDiv_step3_detail': 'V_out = R₂/(R₁+R₂) × V_in. Voltage resistance ratio ke mutabiq divide hota hai. Knob ghumao — volume badalta hai!',
  'lab.p10_potDiv_trace1': 'V_out = {vout} V',
  'lab.p10_potDiv_real_life': 'Audio equipment mein volume knobs potential dividers hain — sliding contact resistive track par chalta hai, loudness control karta hai.',
  'lab.p10_potDiv_practice_q': '9V battery R₁=1kΩ, R₂=500Ω. R₂ across V_out kya hai?',
  'lab.p10_potDiv_practice_hint': 'V_out = 500/(1000+500) × 9 = 3V',
  'lab.p10_potDiv_correct_fb': 'Sahi! 3V. Ratio R₂/(R₁+R₂) = 500/1500 = 1/3.',
  'lab.p10_potDiv_incorrect_fb': 'V_out = R₂/(R₁+R₂)×V_in = 500/1500×9 = 3V',
  'lab.p10_potDiv_vin_label': 'Input Voltage (V_in)',
  'lab.p10_potDiv_r1_label': 'R₁',
  'lab.p10_potDiv_r2_label': 'R₂ (output across)',
  'lab.p10_potDiv_placeholder': 'V_out (V)...',
  'lab.p10_potDiv_adjust_desc': 'Resistors adjust karein voltage divide kaise hota hai dekhne ke liye.',

  'lab.p10_radDecay_title': 'Derivation: Radioactive Decay Formula',
  'lab.p10_radDecay_subtitle': 'Exponential decay law N = N₀/2ⁿ hasil karna',
  'lab.p10_radDecay_final_desc': 'Radioactive nuclei ke liye exponential decay law',
  'lab.p10_radDecay_step1_label': '1 Half-Life Ke Baad',
  'lab.p10_radDecay_step2_label': '2 Half-Lives Ke Baad',
  'lab.p10_radDecay_step3_label': 'n Half-Lives Ke Baad',
  'lab.p10_radDecay_step4_label': 'Half-Lives ki Tadaad',
  'lab.p10_radDecay_step1_detail': 'Ek purani lakdi ka aala mila. Carbon-14 dating jawab deta hai. Ek half-life (5,730 years) ke baad, aadhe reh jatay hain: N₁ = ½ N₀.',
  'lab.p10_radDecay_step2_detail': 'Do half-lives (11,460 years) ke baad, sirf ek chauthai rehti: N₂ = (½)² N₀.',
  'lab.p10_radDecay_step3_detail': 'n half-lives ke baad: N = (½)ⁿ N₀ = N₀/2ⁿ. Yeh exponential decay hai.',
  'lab.p10_radDecay_step4_detail': 'N = N₀/2^(t/T½). Agar tool mein 25% original C-14 hai, n = 2 half-lives = 11,460 years purana.',
  'lab.p10_radDecay_trace1': 'N = {remaining} nuclei',
  'lab.p10_radDecay_real_life': 'Smoke detectors mein americium-241 hai (432-year half-life). Yeh air ionize karta hai; smoke is current ko disrupt karta hai, alarm bajata hai.',
  'lab.p10_radDecay_practice_q': 'Sample 800 nuclei se start, half-life=5 years. 15 years baad kitne rehte hain?',
  'lab.p10_radDecay_practice_hint': 'n = 15/5 = 3. N = 800/2³ = 100',
  'lab.p10_radDecay_correct_fb': 'Sahi! 100 nuclei. 800→400→200→100 (3 half-lives).',
  'lab.p10_radDecay_incorrect_fb': 'n = 15/5 = 3. N = 800/2³ = 800/8 = 100',
  'lab.p10_radDecay_no_label': 'Initial Nuclei (N₀)',
  'lab.p10_radDecay_hl_label': 'Half-Life (T½)',
  'lab.p10_radDecay_time_label': 'Total Time (Δt)',
  'lab.p10_radDecay_placeholder': 'Remaining nuclei...',
  'lab.p10_radDecay_adjust_desc': 'Half-life aur time adjust karein exponential decay dekhne ke liye.',

  'lab.p10_resist_title': 'Derivation: Resistivity',
  'lab.p10_resist_subtitle': 'Resistivity resistance aur geometry se hasil karna',
  'lab.p10_resist_final_desc': 'Resistivity = Resistance × Area / Length (Ω·m)',
  'lab.p10_resist_step1_label': 'Resistance Geometry Par Munsar Hai',
  'lab.p10_resist_step2_label': 'Proportionality Constant Dakhil Karein',
  'lab.p10_resist_step3_label': 'Resistivity ke Liye Dobara Arrange Karein',
  'lab.p10_resist_step1_detail': 'Electrician naye ghar mein wiring karta hai. R ∝ L/A. Lambi wires zyada resist karti hain; moti wires kam.',
  'lab.p10_resist_step2_detail': 'R = ρ × L/A. ρ resistivity hai — material ka inherent current opposition. Copper ρ = 1.68×10⁻⁸ Ω·m.',
  'lab.p10_resist_step3_detail': 'ρ = R × A / L. Silver ki lowest resistivity (1.59×10⁻⁸) lekin bohat mehngi. Copper practical champion hai.',
  'lab.p10_resist_trace1': 'ρ = {rho} Ω·m',
  'lab.p10_resist_real_life': 'Heating elements nichrome (ρ=1.1×10⁻⁶ Ω·m) istemal karte hain — high resistivity electricity ko heat mein badalti hai.',
  'lab.p10_resist_practice_q': 'Copper wire 5m lamba, A=1×10⁻⁶ m², R=0.084Ω. Resistivity maloom karein.',
  'lab.p10_resist_practice_hint': 'ρ = 0.084 × 10⁻⁶ / 5 = 1.68×10⁻⁸ Ω·m',
  'lab.p10_resist_correct_fb': 'Sahi! 1.68×10⁻⁸ Ω·m — copper ki resistivity, electrical wiring ke liye standard!',
  'lab.p10_resist_incorrect_fb': 'ρ = R×A/L = 0.084×10⁻⁶/5 = 1.68×10⁻⁸ Ω·m',
  'lab.p10_resist_r_label': 'Resistance (R)',
  'lab.p10_resist_l_label': 'Length (L)',
  'lab.p10_resist_a_label': 'Area (A)',
  'lab.p10_resist_placeholder': 'ρ in Ω·m...',
  'lab.p10_resist_adjust_desc': 'Wire properties adjust karein resistivity in action dekhne ke liye.',

  'lab.p10_ser_title': 'Derivation: Series Resistance',
  'lab.p10_ser_subtitle': 'Series ke liye R_eq = R₁ + R₂ + R₃ hasil karna',
  'lab.p10_ser_final_desc': 'Series mein tamam resistances ka sum',
  'lab.p10_ser_step1_label': 'Voltage Drops Jortay Hain',
  'lab.p10_ser_step2_label': 'Current ko Factor Out Karein',
  'lab.p10_ser_step3_label': 'Ahem Usool',
  'lab.p10_ser_step1_detail': 'Purane Christmas lights yad hain jahan EK bulb kharab to POORI string andheri? Yeh series wiring hai. V = V₁ + V₂ + V₃.',
  'lab.p10_ser_step2_detail': 'Ohm ke law se: I×Req = I×R₁ + I×R₂ + I×R₃. Har bulb mein ek hi current behta hai — sirf ek raasta.',
  'lab.p10_ser_step3_detail': 'Req = R₁ + R₂ + R₃. Teen 100Ω bulbs series mein 300Ω total. Zyada bulbs = zyada resistance = har ek aur dim.',
  'lab.p10_ser_trace1': 'R_eq = {req} Ω, I = {i} mA',
  'lab.p10_ser_real_life': 'Purane Christmas lights series mein andheri ho jate hain jab ek bulb fail hota hai — toota bulb iklauta current path todta hai.',
  'lab.p10_ser_practice_q': 'Teen resistors 200Ω, 300Ω, 500Ω series mein 10V battery ke saath. Total resistance maloom karein.',
  'lab.p10_ser_practice_hint': 'R_eq = 200 + 300 + 500 = 1000Ω',
  'lab.p10_ser_correct_fb': 'Sahi! 1000Ω. Current I = 10/1000 = 10 mA teeno mein se.',
  'lab.p10_ser_incorrect_fb': 'R_eq = R₁+R₂+R₃ = 200+300+500 = 1000Ω',
  'lab.p10_ser_r1_label': 'R₁',
  'lab.p10_ser_r2_label': 'R₂',
  'lab.p10_ser_r3_label': 'R₃',
  'lab.p10_ser_placeholder': 'R_eq in Ω...',
  'lab.p10_ser_adjust_desc': 'Resistors adjust karein series equivalent dekhne ke liye.',

  'lab.p10_shElec_title': 'Derivation: Specific Heat (Electrical Method)',
  'lab.p10_shElec_subtitle': 'Electrical heating aur calorimetry se c_l hasil karna',
  'lab.p10_shElec_final_desc': 'Electrical heating se liquid ki specific heat',
  'lab.p10_shElec_step1_label': 'Heater Se Energy Supply',
  'lab.p10_shElec_step2_label': 'Liquid + Calorimeter Ka Heat',
  'lab.p10_shElec_step3_label': 'Final Formula',
  'lab.p10_shElec_step1_detail': 'Aap electric kettle bhar karte hain aur switch on. Heating element electrical energy heat mein badalta hai: Q_heater = V×I×t.',
  'lab.p10_shElec_step2_detail': 'Heat dono ko garam karta hai: water AUR metal calorimeter. Q_heater = m_l c_l ΔT + m_c c_c ΔT.',
  'lab.p10_shElec_step3_detail': 'c_l = (VIt - m_c c_c ΔT) / (m_l ΔT). Calorimeter ka hissa ghatao, water mass aur temperature rise se divide karo.',
  'lab.p10_shElec_trace1': 'c_l = {cl} J/kg·K',
  'lab.p10_shElec_real_life': 'Electric kettle 1L water 20°C se 100°C tak 336,000 J leta hai. 2000W par, taqreeban 168 seconds lagte hain.',
  'lab.p10_shElec_practice_q': '12V, 3A heater 150s calorimeter mein (m_c=0.08kg, c_c=900) 0.3kg liquid ke saath. Temp 22°C→42°C. Specific heat maloom karein.',
  'lab.p10_shElec_practice_hint': 'Q = 12×3×150 = 5400J. ΔT=20. c_l = (5400 - 0.08×900×20)/(0.3×20)',
  'lab.p10_shElec_correct_fb': 'Sahi! ~780 J/kg·K — vegetable oils ke liye typical!',
  'lab.p10_shElec_incorrect_fb': 'c_l = (VIt - m_c c_c ΔT) / (m_l ΔT) istemal karein',
  'lab.p10_shElec_v_label': 'Voltage (V)',
  'lab.p10_shElec_i_label': 'Current (I)',
  'lab.p10_shElec_t_label': 'Heating Time (t)',
  'lab.p10_shElec_ml_label': 'Liquid Mass (m_l)',
  'lab.p10_shElec_placeholder': 'c_l (J/kg·K)...',
  'lab.p10_shElec_adjust_desc': 'Values adjust karein electrical calorimetry specific heat determine karte dekhne ke liye.',

  'lab.p10_shMix_title': 'Derivation: Specific Heat (Method of Mixtures)',
  'lab.p10_shMix_subtitle': 'Calorimetry aur conservation of energy se c_s hasil karna',
  'lab.p10_shMix_final_desc': 'Mixture method se solid ki specific heat',
  'lab.p10_shMix_step1_label': 'Conservation of Energy',
  'lab.p10_shMix_step2_label': 'Solid Ka Heat Loss',
  'lab.p10_shMix_step3_label': 'Water + Calorimeter Ka Heat Gain',
  'lab.p10_shMix_step4_label': 'c_s ke Liye Hal Karein',
  'lab.p10_shMix_step1_detail': 'Aap chai bana rahe hain. Garam pani mein thanda doodh milayein. Heat lost = heat gained.',
  'lab.p10_shMix_step2_detail': 'Q_s = m_s c_s (T₂ - T₃). Garam solid thanda hota hai, heat khota hai.',
  'lab.p10_shMix_step3_detail': 'Q_w + Q_c = (m_w c_w + m_c c_c)(T₃ - T₁). Dono liquid aur container heat absorb karte hain.',
  'lab.p10_shMix_step4_detail': 'c_s = (m_w c_w + m_c c_c)(T₃ - T₁) / (m_s (T₂ - T₃)). Sab values lab mein measurable hain.',
  'lab.p10_shMix_trace1': 'c_s = {cs} J/kg·K',
  'lab.p10_shMix_real_life': 'Chemistry labs mein calorimetry yahi principle istemal karti hai — known masses ko known temperatures par milakar unknown material ki specific heat maloom karna.',
  'lab.p10_shMix_practice_q': '0.2kg metal 90°C par 0.15kg water 25°C mein. Calorimeter: 0.08kg, c_c=900. Final temp=28°C. c_s maloom karein.',
  'lab.p10_shMix_practice_hint': 'c_s = (0.15×4186+0.08×900)(28-25)/(0.2×(90-28))',
  'lab.p10_shMix_correct_fb': 'Sahi! ~386 J/kg·K — yeh copper se match karta hai!',
  'lab.p10_shMix_incorrect_fb': 'c_s = (m_w c_w + m_c c_c)(T₃ - T₁) / (m_s(T₂ - T₃)) istemal karein',
  'lab.p10_shMix_ms_label': 'Solid Mass (m_s)',
  'lab.p10_shMix_mw_label': 'Water Mass (m_w)',
  'lab.p10_shMix_t2_label': 'Solid Temp (T₂)',
  'lab.p10_shMix_t3_label': 'Final Temp (T₃)',
  'lab.p10_shMix_placeholder': 'c_s (J/kg·K)...',
  'lab.p10_shMix_adjust_desc': 'Values adjust karein calorimetry specific heat kaise determine karti hai dekhne ke liye.',

  'lab.p10_tempCo_title': 'Derivation: Temperature Coefficient of Resistivity',
  'lab.p10_tempCo_subtitle': 'Resistivity ka temperature coefficient α hasil karna',
  'lab.p10_tempCo_final_desc': 'Temperature coefficient of resistivity (/°C)',
  'lab.p10_tempCo_step1_label': 'Resistivity Temperature Ke Saath Badalti Hai',
  'lab.p10_tempCo_step2_label': 'Proportionality Constant Dakhil Karein',
  'lab.p10_tempCo_step3_label': 'α ke Liye Dobara Arrange Karein',
  'lab.p10_tempCo_step4_label': 'Final Resistivity Formula',
  'lab.p10_tempCo_step1_detail': 'Aap ka phone freezing winter mein jaldi marta hai. Resistance temperature ke saath badalta hai. Resistivity mein change ∝ initial resistivity × ΔT.',
  'lab.p10_tempCo_step2_detail': 'ρ_T - ρ₀ = α ρ₀ ΔT. Copper ke liye α positive hai — resistance garam hone par BARHTA hai.',
  'lab.p10_tempCo_step3_detail': 'α = (ρ_T - ρ₀)/(ρ₀ ΔT). Copper α = 0.0039/°C. Copper wire 50°C garam honey par resistance 19.5% barhta hai.',
  'lab.p10_tempCo_step4_detail': 'ρ_T = ρ₀[1 + α(T - T₀)]. Carbon aur semiconductors ka α NEGATIVE hota hai — digital thermometers mein thermistors istemal hote hain.',
  'lab.p10_tempCo_trace1': 'α = {alpha}/°C',
  'lab.p10_tempCo_real_life': 'Incandescent bulbs ka cold resistance ~40Ω lekin hot resistance ~400Ω — 10× increase surge current explain karta hai jab switch on karte hain.',
  'lab.p10_tempCo_practice_q': 'Copper ρ₀=1.68×10⁻⁸ 20°C par. 70°C par ρ_T=2.01×10⁻⁸. α maloom karein.',
  'lab.p10_tempCo_practice_hint': 'α = (2.01-1.68)×10⁻⁸/(1.68×10⁻⁸×50) = 0.0039/°C',
  'lab.p10_tempCo_correct_fb': 'Sahi! 0.0039/°C. Copper resistance 0.39% per °C barhta hai.',
  'lab.p10_tempCo_incorrect_fb': 'α = (ρ_T-ρ₀)/(ρ₀ΔT) = (0.33×10⁻⁸)/(1.68×10⁻⁸×50)',
  'lab.p10_tempCo_rho0_label': 'Initial Resistivity (ρ₀)',
  'lab.p10_tempCo_rhoT_label': 'Resistivity at T (ρ_T)',
  'lab.p10_tempCo_dt_label': 'Temp Change (ΔT)',
  'lab.p10_tempCo_placeholder': 'α in /°C...',
  'lab.p10_tempCo_adjust_desc': 'Values adjust karein temperature coefficient maloom karne ke liye.',

  'lab.p10_trans_title': 'Derivation: Ideal Transformer Power',
  'lab.p10_trans_subtitle': 'Power conservation se I_p V_p = I_s V_s hasil karna',
  'lab.p10_trans_final_desc': 'Ideal transformers mein power conserved',
  'lab.p10_trans_step1_label': 'Ideal Transformer Assumption',
  'lab.p10_trans_step2_label': 'Power Formula ki Jagah Substitute Karein',
  'lab.p10_trans_step3_label': 'Secondary Current ke Liye Hal Karein',
  'lab.p10_trans_step4_label': 'Turns Ratio Relation',
  'lab.p10_trans_step1_detail': 'Power plants 25,000V par generate karte hain. Transformers 500,000V tak step up karte hain. Ideal transformer power conserve karta hai: Power_in = Power_out.',
  'lab.p10_trans_step2_detail': 'P = IV dono coils ke liye: I_p V_p = I_s V_s. High voltage = low current = low I²R heating losses.',
  'lab.p10_trans_step3_detail': 'I_s = (V_p/V_s) × I_p. Step-down transformer (500kV→230V) ka V_p/V_s ≈ 2174. Current 2174 guna barhta hai.',
  'lab.p10_trans_step4_detail': 'V_s/V_p = N_s/N_p = I_p/I_s. Voltage ratio turns ratio ke barabar, current ratio ka ulta.',
  'lab.p10_trans_trace1': 'I_s = {is} A, P = {p} W',
  'lab.p10_trans_real_life': 'Phone chargers step-down transformers istemal karte hain — 230V wall se 5V USB tak. Turns ratio 46:1 voltage safely reduce karta hai.',
  'lab.p10_trans_practice_q': 'Step-down: V_p=240V, I_p=2A, V_s=24V. I_s maloom karein.',
  'lab.p10_trans_practice_hint': 'I_s = (240×2)/24 = 20A',
  'lab.p10_trans_correct_fb': 'Sahi! 20A. Voltage 10× step down, current 10× step up. 480W = 480W.',
  'lab.p10_trans_incorrect_fb': 'I_s = I_p × V_p / V_s = 2 × 240 / 24 = 20A',
  'lab.p10_trans_vp_label': 'Primary V_p',
  'lab.p10_trans_ip_label': 'Primary I_p',
  'lab.p10_trans_vs_label': 'Secondary V_s',
  'lab.p10_trans_placeholder': 'I_s in Amps...',
  'lab.p10_trans_adjust_desc': 'Voltages/current adjust karein power conservation dekhne ke liye.',

  'lab.p10_transGain_title': 'Derivation: Transistor Current Gain',
  'lab.p10_transGain_subtitle': 'β = I_C/I_B aur α = I_C/I_E hasil karna',
  'lab.p10_transGain_final_desc': 'Transistor current relationships aur gains',
  'lab.p10_transGain_step1_label': 'Emitter Current = Sum',
  'lab.p10_transGain_step2_label': 'Current Gain β (Beta)',
  'lab.p10_transGain_step3_label': 'Current Gain α (Alpha)',
  'lab.p10_transGain_step4_label': 'Amplification',
  'lab.p10_transGain_step1_detail': 'Concert mein, singer microphone mein fıs-fıs karta hai aur stadium bhar jata hai. Andar ek chota transistor amplify karta hai. I_E = I_B + I_C.',
  'lab.p10_transGain_step2_detail': 'β = I_C/I_B. Current gain typically 50-400. Choti base current bari collector current control karti hai.',
  'lab.p10_transGain_step3_detail': 'α = I_C/I_E, hamesha 1 se thoda kam (0.95-0.99). α = β/(β+1).',
  'lab.p10_transGain_step4_detail': 'I_C = β × I_B. 1μA base change 200μA collector change produce karta hai agar β=200. Aap ke smartphone mein billions amplify kar rahe hain!',
  'lab.p10_transGain_trace1': 'β = {beta}, α = {alpha}',
  'lab.p10_transGain_real_life': 'Hearing aids β=100+ ke transistors istemal karte hain — chota microphone signal (μA) speaker ko mA level par chlata hai, 100× amplify!',
  'lab.p10_transGain_practice_q': 'Transistor mein I_B=0.05 mA aur I_C=10 mA. β maloom karein.',
  'lab.p10_transGain_practice_hint': 'β = 10/0.05 = 200',
  'lab.p10_transGain_correct_fb': 'Sahi! β=200. 0.05 mA 10 mA control karta hai — 200× amplification!',
  'lab.p10_transGain_incorrect_fb': 'β = I_C / I_B = 10 / 0.05 = 200',
  'lab.p10_transGain_ib_label': 'Base Current (I_B)',
  'lab.p10_transGain_ic_label': 'Collector Current (I_C)',
  'lab.p10_transGain_placeholder': 'β (gain)...',
  'lab.p10_transGain_adjust_desc': 'Currents adjust karein transistor gain dekhne ke liye.',

  'lab.p10_volExp_title': 'Derivation: Volumetric Thermal Expansion',
  'lab.p10_volExp_subtitle': 'Volumetric expansion ka coefficient β hasil karna',
  'lab.p10_volExp_final_desc': 'Coefficient of volumetric thermal expansion',
  'lab.p10_volExp_step1_label': 'Volume Change Proportional Hai',
  'lab.p10_volExp_step2_label': 'Proportionality Constant Dakhil Karein',
  'lab.p10_volExp_step3_label': 'β ke Liye Dobara Arrange Karein',
  'lab.p10_volExp_step4_label': 'β aur α ka Talluq',
  'lab.p10_volExp_step1_detail': 'Garmiyan mein aap ki car ke fuel tank ka petrol phailta hai. ΔV ∝ V₀ × ΔT. Petrol pumps is liye calibrated hain.',
  'lab.p10_volExp_step2_detail': 'ΔV = β V₀ ΔT. β volumetric expansion ka coefficient hai. Gasoline β ≈ 9.5×10⁻⁴/°C.',
  'lab.p10_volExp_step3_detail': 'β = ΔV/(V₀ ΔT). Isotropic solids ke liye, β ≈ 3α. Volume = L³.',
  'lab.p10_volExp_step4_detail': 'β = 3α. Yahi wajah hai hot air balloons oopar jaate hain — andar ki hawa phailti hai, kam dense hoti hai, aur tairti hai.',
  'lab.p10_volExp_trace1': 'ΔV = {dv} cm³',
  'lab.p10_volExp_real_life': 'Car engine thermostats wax pellet istemal karte hain jo temperature ke saath phailta hai — 88°C par melt hota hai, coolant valve kholta hai overheating rokne ke liye.',
  'lab.p10_volExp_practice_q': '0.5 m³ alcohol tank 10°C se 30°C tak garam. β=1.1×10⁻³/°C. ΔV maloom karein.',
  'lab.p10_volExp_practice_hint': 'ΔV = 1.1×10⁻³ × 0.5 × 20 = 0.011 m³',
  'lab.p10_volExp_correct_fb': 'Sahi! 0.011 m³ (11 L). Liquids solids se zyada phailti hain!',
  'lab.p10_volExp_incorrect_fb': 'ΔV = β × V₀ × ΔT. ΔT = 30-10 = 20°C.',
  'lab.p10_volExp_vo_label': 'Original Volume (V₀)',
  'lab.p10_volExp_dt_label': 'Temp Change (ΔT)',
  'lab.p10_volExp_beta_label': 'Expansion Coeff (β)',
  'lab.p10_volExp_placeholder': 'ΔV in m³...',
  'lab.p10_volExp_adjust_desc': 'Values adjust karein volume expansion dekhne ke liye.',

  // --- P11 Vectors & Dot Product ---
  'lab.p11_vectors_title': 'Vectors aur Dot Product',
  'lab.p11_vectors_theory_title': 'Vector Resolution aur Work',
  'lab.p11_vectors_theory_p1': 'Work ko Force aur Displacement vectors ke dot product se define kiya jata hai:',
  'lab.p11_vectors_theory_p2': 'W = F · D = |F||D|cos(θ)',
  'lab.p11_vectors_theory_p3': 'Ya components mein tod kar:',
  'lab.p11_vectors_theory_p4': 'W = F_x D_x + F_y D_y',
  'lab.p11_vectors_theory_li1': '<strong>Force (F)</strong> trolley par lagne wali dhakkan ko zahir karta hai.',
  'lab.p11_vectors_theory_li2': '<strong>Displacement (D)</strong> harkat ko zahir karta hai.',
  'lab.p11_vectors_theory_li3': 'Neeche sliders se magnitudes aur angles adjust karein.',
  'lab.p11_vectors_theory_li4': 'Apne parameters ki bunyad par total work ka hisab lagayein.',
  'lab.p11_vectors_sim_title': 'Vector Mapping',
  'lab.p11_vectors_legend_force': 'Force',
  'lab.p11_vectors_legend_disp': 'Displacement',
  'lab.p11_vectors_assess_title': 'Work ka Hisab Lagayein',
  'lab.p11_vectors_data_f': '<strong>F</strong> = {fMag} N {fAngle}° par',
  'lab.p11_vectors_data_d': '<strong>D</strong> = {dMag} m {dAngle}° par',
  'lab.p11_vectors_hint': 'Ishara: F aur D ke components nikalain ya angle difference istemal karein.',
  'lab.p11_vectors_input_label': 'Work Done (Joules):',
  'lab.p11_vectors_placeholder': 'masalan 250',
  'lab.p11_vectors_correct_fb': 'Sahi! Aap ne dot product (Work) kamyabi se hisab kar liya.',
  'lab.p11_vectors_incorrect_fb': 'Ghalat. F aur D ko x aur y components mein tod kar W = Fx*Dx + Fy*Dy istemal karein. Asli jawab {actual} J hai.',
  'lab.p11_vectors_slider_fmag': 'Force Magnitude (N)',
  'lab.p11_vectors_slider_fangle': 'Force Zawiya (°)',
  'lab.p11_vectors_slider_dmag': 'Disp. Magnitude (m)',
  'lab.p11_vectors_slider_dangle': 'Disp. Zawiya (°)',

  // --- P11 Physical Quantities & Errors ---
  'lab.p11_quantities_title': 'Tabeeghati Miqdar aur Kharabiyaan',
  'lab.p11_quantities_theory_title': 'Sahihgi aur Sakhti',
  'lab.p11_quantities_theory_p1': '<strong>Accuracy (Sahihgi)</strong> se muraad hai ke naapi gayi value asli ya maqbool qeemat ke kitni qareeb hai. Achi accuracy ka matlab kam <em>systematic error</em>.',
  'lab.p11_quantities_theory_p2': '<strong>Precision (Sakhti)</strong> se muraad hai ke ek hi cheez ki bar-bar ki gayi paimayish aapas mein kitni qareeb hain. Achi precision ka matlab kam <em>random error</em>.',
  'lab.p11_quantities_theory_p3': 'Hamare target shooting simulator mein, nishanay ka markaz (0,0) asli qeemat ko zahir karta hai.',
  'lab.p11_quantities_theory_li1': 'Target par click kar ke shots simulate karein.',
