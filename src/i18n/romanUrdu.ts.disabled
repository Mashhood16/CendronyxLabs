  // --- Class 9 Physics Labs ---
  // Pressure Lab
  'lab.p9_pressure_theory': 'Fluid pressure depth ke saath barhti hai oopar ke fluid ke weight ki wajah se. Pressure P depth h par density ρ mein: P = ρ × g × h. Zyada pressure ke natije mein zyada ejection velocity (v) hoti hai hole se.',
  'lab.p9_pressure_instructions': '1. Can ke side par black plugs par click karein taake water spurt out ho.\n2. Stream kitni door travel karti hai dekhein.\n3. Red measuring tool ko ground par drag karein splash point ki distance measure karne ke liye.\n4. Apni readings Data table mein record karein.',
  'lab.p9_pressure_section1': '1. Setup aur Theory',
  'lab.p9_pressure_section2': '2. Interactive Simulation',
  'lab.p9_pressure_section3': '3. Data Logging aur Assessment',
  'lab.p9_pressure_hint': 'P = ρgh. ρ = 1000 kg/m³, g = 9.8 m/s² istemal karein. 80cm ko 0.8m mein badlein!',
  'lab.p9_pressure_depth_header': 'Hole Depth (cm)',
  'lab.p9_pressure_range_header': 'Splash Range (cm)',
  'lab.p9_pressure_assessment_q': 'Maan lete hain pani ki density 1000 kg/m³ hai aur g = 9.8 m/s², lowest hole (depth = 80 cm) par theoretical fluid pressure (Pascals mein) calculate karein.',
  'lab.p9_pressure_correct_fb': 'Sahi! (7840 Pa)',
  'lab.p9_pressure_incorrect_fb': 'Ghalat. Dobara koshish karein.',
  'lab.p9_pressure_no_data': 'Koi measurements record nahi hain.',
  'lab.p9_pressure_add': 'Shamil karein',
  'lab.p9_pressure_placeholder_depth': 'Depth (cm)',
  'lab.p9_pressure_placeholder_range': 'Range (cm)',
  'lab.p9_pressure_placeholder_pressure': 'Pressure in Pa...',

  // Friction Lab
  'lab.p9_friction_theory': 'Friction woh force hai jo solid surfaces ki relative motion ke khilaf mazahemat karti hai. Static friction ko overcome karna padta hai movement shuru karne ke liye. Ek baar move karne par, kam kinetic friction apply hota hai. Rolling friction sliding friction se kaam hota hai.',
  'lab.p9_friction_instructions': 'Mass aur surface mode adjust karein, phir static vs kinetic friction observe karne ke liye start pulling karein. Apna data table mein record karein.',
  'lab.p9_friction_section1': '1. Setup aur Theory',
  'lab.p9_friction_section2': '2. Interactive Simulation',
  'lab.p9_friction_section3': '3. Data aur Analysis',
  'lab.p9_friction_hint': 'F_max = μs × m × g. Kinetic friction usually static se kam hota hai. Rolling mode try karein compare karne ke liye!',
  'lab.p9_friction_mass_label': 'Block Mass: {mass} kg',
  'lab.p9_friction_mode_label': 'Surface Mode',
  'lab.p9_friction_mode_sliding': 'Wood on Wood (Sliding)',
  'lab.p9_friction_mode_rolling': 'Wood on Pencils (Rolling)',
  'lab.p9_friction_mode_unknown': 'Unknown Material (Sliding)',
  'lab.p9_friction_start': 'Start Pulling',
  'lab.p9_friction_record': 'Record Max aur Kinetic Forces',
  'lab.p9_friction_table_mode': 'Mode',
  'lab.p9_friction_table_mass': 'Mass (kg)',
  'lab.p9_friction_table_peak': 'Peak (N)',
  'lab.p9_friction_table_kinetic': 'Kinetic (N)',
  'lab.p9_friction_no_data': 'Koi data record nahi hua abhi tak.',
  'lab.p9_friction_assessment_q': 'Unknown Material mode select karein, simulation run karein, aur Peak Force record karein. Us ka coefficient of static friction (μs) calculate karein. (g = 9.8 m/s² maan lein)',
  'lab.p9_friction_assessment_hint': 'Formula istemal karein: μs = Peak Force / (Mass × 9.8)',
  'lab.p9_friction_correct_fb': 'Sahi! Behtareen calculation.',
  'lab.p9_friction_incorrect_fb': 'Ghalat. Formula istemal karein: μs = Peak Force / (Mass × 9.8)',
  'lab.p9_friction_placeholder': 'μs darj karein...',

  // Inertia Lab
  'lab.p9_inertia_theory': "Newton's First Law of Motion (Law of Inertia): Ek object rest par rest par hi rehta hai, aur motion mein object motion mein hi rehta hai jab tak ek unbalanced force us par action na kare. Inertia object ki tendency hai apni state of motion mein changes ko resist karne ki. Jitna zyada mass, utni zyada inertia.",
  'lab.p9_inertia_section1': 'Theory: Newton ka Pehla Law',
  'lab.p9_inertia_section2': 'Simulator',
  'lab.p9_inertia_section3': 'Tajzia (Analysis)',
  'lab.p9_inertia_flick_label': 'Flick Force: {force} N',
  'lab.p9_inertia_flick_btn': 'FLICK!',
  'lab.p9_inertia_q1': 'Jab zor se flick kiya gaya to coin glass mein kyun gira?',
  'lab.p9_inertia_q1_a': 'Card ne apni kinetic energy coin ko transfer kar di.',
  'lab.p9_inertia_q1_b': 'Coin ki inertia ne sideways motion ka resist kiya jabke gravity ne usay neeche khench liya.',
  'lab.p9_inertia_q1_c': 'Flicking force ne coin ko seedha neeche dhakel diya.',
  'lab.p9_inertia_q2': 'Agar aap card ko flick karne ke bajaye aahista se khenchein, to kya hota hai?',
  'lab.p9_inertia_q2_a': 'Static friction toot-ta nahi; coin card ke saath move karta hai.',
  'lab.p9_inertia_q2_b': 'Coin hawa mein tairne lagega.',
  'lab.p9_inertia_q2_c': 'Coin turant glass mein gir jata hai.',
  'lab.p9_inertia_submit': 'Jawab jamah karein',
  'lab.p9_inertia_correct_fb': 'Shabash! Rapid force static friction ko jaldi overcome kar leti hai, jisse coin ki inertia usay glass ke oopar rakhti hai jab tak woh girti nahi.',
  'lab.p9_inertia_incorrect_fb': 'Kuch jawabat ghalat hain. Inertia aur friction ki theory ka dubara jaiza lein aur dobara koshish karein.',

  // Kinematics Lab
  'lab.p9_kinematics_theory1': 'Average speed total distance traveled ko total time taken se divide karne se milti hai. Speed (v) = Distance (d) / Time (t)',
  'lab.p9_kinematics_theory2': 'Measurement lete waqt, tamam certain digits aur ek estimated digit record karein. Agar ruler par 1mm ke marks hain, to aap 0.1mm (0.01cm) tak estimate kar sakte hain.',
  'lab.p9_kinematics_section1': 'Theory',
  'lab.p9_kinematics_section2': 'Cricket Pitch Simulator',
  'lab.p9_kinematics_section3': 'Tajzia (Analysis)',
  'lab.p9_kinematics_hint': 'Speed = Distance ÷ Time. Pitch 20.12m hai. Stopwatch se time sahi measure karne ki koshish karein!',
  'lab.p9_kinematics_bowl_btn': 'Bowl Delivery',
  'lab.p9_kinematics_stopwatch': 'Digital Stopwatch',
  'lab.p9_kinematics_start': 'SHURU',
  'lab.p9_kinematics_stop': 'ROKEIN',
  'lab.p9_kinematics_distance_label': 'Distance: {d} m',
  'lab.p9_kinematics_time_label': 'Time (aap ka measurement): {t} s',
  'lab.p9_kinematics_calc_speed': 'Speed Check karein',
  'lab.p9_kinematics_speed_placeholder': 'masalan 32.5',
  'lab.p9_kinematics_correct_fb': 'Aap ke time ki bunyad par sahi! (Asli speed {v} m/s thi)',
  'lab.p9_kinematics_incorrect_fb': 'Ghalat. Distance ko APNE time se divide karein.',
  'lab.p9_kinematics_sigfig_title': '2. Significant Figures',
  'lab.p9_kinematics_sigfig_desc': 'Red line textbook ke kinare ko dikhati hai. Ruler ke marks centimeters (cm) mein hain. Length ko correct significant figures mein record karein.',
  'lab.p9_kinematics_sigfig_placeholder': 'masalan 24.5',
  'lab.p9_kinematics_sigfig_submit': 'Jamah karein',
  'lab.p9_kinematics_sigfig_correct': 'Sahi! 3 sig figs.',
  'lab.p9_kinematics_sigfig_incorrect': 'Ghalat. Marks ko ghaur se dekhein. Chhotay mark ke aage ek digit ka estimate karein.',

  // Measurement Tools Lab
  'lab.p9_measurement_theory': 'Vernier Caliper ek aala hai jo internal aur external dimensions ko sahi napta hai. Main Scale: millimeters (mm) mein parti hai. Vernier scale par zero ke left wala mark parhein. Vernier Scale: 0.1 mm tak precision deti hai. Vernier mark jo Main scale ke kisi mark se bilkul milay, woh dekhein.',
  'lab.p9_measurement_section1': 'Theory: Measurement',
  'lab.p9_measurement_section2': 'Interactive Simulator',
  'lab.p9_measurement_section3': 'Analysis aur Record',
  'lab.p9_measurement_formula': 'Total Reading = Main Scale Reading + (Vernier Division × Least Count). Yahan Least Count = 0.1 mm',
  'lab.p9_measurement_place_btn': 'Object rakhein',
  'lab.p9_measurement_new_btn': 'Naya Object',
  'lab.p9_measurement_jaw_label': 'Jaw Position adjust karein: {pos} mm',
  'lab.p9_measurement_reading_label': 'Reading darj karein (mm)',
  'lab.p9_measurement_reading_placeholder': 'masalan 15.3',
  'lab.p9_measurement_check_btn': 'Jawab check karein',
  'lab.p9_measurement_clamp_message': 'Measuring se pehle object ko sahi tarah clamp karein.',
  'lab.p9_measurement_correct_fb': 'Sahi! Object bilkul {w} mm chaura hai.',
  'lab.p9_measurement_incorrect_fb': 'Ghalat. Vernier zero se pehle main scale check karein, phir matching vernier line dhoondhein.',

  // Springs Lab
  'lab.p9_springs_theory': 'Jab ideal (massless) spring balances series mein jure hote hain, tension poore chain mein ek jaisi hoti hai. Is liye har spring wohi force parta hai. Lekin system ka total extension har individual spring ke extension ka sum hota hai.',
  'lab.p9_springs_instructions': 'Springs ki tadaad aur hanging mass adjust karein. Dekhein kaise force reading har spring par ek jaisi hai jabke total extension barhta hai.',
  'lab.p9_springs_section1': '1. Setup aur Theory',
  'lab.p9_springs_section2': '2. Interactive Simulation',
  'lab.p9_springs_section3': '3. Data Logging aur Assessment',
  'lab.p9_springs_hint': 'Series mein springs ka tension ek jaisa hota hai. Total extension har spring ke extension ka sum hai. 1/k_eq = 1/k1 + 1/k2 + ...',
  'lab.p9_springs_num_label': 'Springs ki tadaad: {n}',
  'lab.p9_springs_mass_label': 'Hanging Mass: {mass} g',
  'lab.p9_springs_placeholder_springs': 'Springs',
  'lab.p9_springs_placeholder_mass': 'Mass (g)',
  'lab.p9_springs_placeholder_reading': 'Top Reading (N)',
  'lab.p9_springs_placeholder_ext': 'Total Ext (cm)',
  'lab.p9_springs_record_btn': 'Trial Record karein',
  'lab.p9_springs_table_springs': 'Springs',
  'lab.p9_springs_table_mass': 'Mass(g)',
  'lab.p9_springs_table_reading': 'Top(N)',
  'lab.p9_springs_table_ext': 'Ext(cm)',
  'lab.p9_springs_no_data': 'Koi data record nahi.',
  'lab.p9_springs_knowledge_check': 'Ilm ka Imtihaan',
  'lab.p9_springs_q1': '1. Agar 4 ek jaisi ideal springs 200g mass ko pakarti hain, to top spring kitna parhti hai (N mein)?',
  'lab.p9_springs_q2': '2. 2 springs series mein equivalent spring constant (N/m) kya hai agar single spring ka k=100 N/m hai?',
  'lab.p9_springs_submit_btn': 'Jawab jamah karein',
  'lab.p9_springs_correct': 'Sahi',
  'lab.p9_springs_incorrect': 'Ghalat',

  // Volume & Density Lab
  'lab.p9_density_theory': 'Density mass per unit volume hoti hai. ρ = m / V. Irregular solid ki density nikalne ke liye: Mass (m) electronic balance se naapein. Initial water volume (V1) measuring cylinder mein naapein. Solid ko poori tarah immerse karein. Final water volume (V2) naapein. Solid ka volume V = V2 - V1 hai. Note: 1 mL pani = 1 cm³ volume.',
  'lab.p9_density_section1': 'Theory: Density',
  'lab.p9_density_section2': 'Laboratory Bench',
  'lab.p9_density_section3': 'Data Record karein',
  'lab.p9_density_hint': 'ρ = m / V. Volume = V2 - V1 (displacement). Cylinder V1=50 mL se start hota hai.',
  'lab.p9_density_tab_table': 'Table',
  'lab.p9_density_tab_balance': 'Balance par rakhein',
  'lab.p9_density_tab_cylinder': 'Cylinder mein dalen',
  'lab.p9_density_tab_reset': 'Reset',
  'lab.p9_density_mass_label': 'Mass (g)',
  'lab.p9_density_v1_label': 'V1 (mL)',
  'lab.p9_density_v2_label': 'V2 (mL)',
  'lab.p9_density_calc_label': 'Calculated Density (g/cm³)',
  'lab.p9_density_mass_placeholder': '0.0',
  'lab.p9_density_v1_placeholder': '0',
  'lab.p9_density_v2_placeholder': '0',
  'lab.p9_density_calc_placeholder': '0.0',
  'lab.p9_density_verify_btn': 'Calculations ki tasdeeq karein',
  'lab.p9_density_measure_error': 'Aap ke raw measurements (Mass, V1, ya V2) ghalat hain. Balance aur cylinder ki reading ghaur se check karein.',
  'lab.p9_density_density_error': 'Measurements sahi hain, lekin aap ka calculated density ghalat hai. ρ = m / (V2 - V1) istemal karein.',
  'lab.p9_density_correct_fb': 'Behtareen! Density {d} g/cm³ hai. Is ki bunyad par, material shayad {material} hai.',

  // Magnetism Fields Lab
  'lab.p9_magfields_theory': 'Magnetic field magnet ke aas-paas ka woh ilaqa hai jahan magnetic forces kaam karti hain. Khaasiyaten: Yeh hamesha North pole se South pole ki taraf ishara karte hain magnet ke bahar. Yeh kabhi ek dosre ko nahi kaat-te. Yeh continuous loops hain jo magnet ke andar se wapas aate hain.',
  'lab.p9_magfields_instructions': '1. Neeche tool select karein.\n2. Compass: Magnet ke aas-paas kahin bhi click karein field direction dekhne ke liye.\n3. Iron Filings: Sprinkle karein overall field pattern dekhne ke liye.',
  'lab.p9_magfields_section1': 'Theory aur Setup',
  'lab.p9_magfields_section2': 'Interactive Simulator',
  'lab.p9_magfields_section3': 'Data Logging aur Analysis',
  'lab.p9_magfields_compass_btn': 'Compass rakhein',
  'lab.p9_magfields_sprinkle_btn': 'Filings sprinkle karein',
  'lab.p9_magfields_clear_btn': 'Sab saaf karein',
  'lab.p9_magfields_table_num': 'Reading #',
  'lab.p9_magfields_table_pos': 'Position (x,y)',
  'lab.p9_magfields_table_angle': 'Zawiya (°)',
  'lab.p9_magfields_no_data': 'Field directions record karne ke liye simulator par compasses rakhein.',
  'lab.p9_magfields_assessment_title': 'Imtihaan',
  'lab.p9_magfields_assessment_q': 'Aap ke mushahidat ki bunyad par, magnet ke center ke bilkul oopar magnetic field ki taqribi direction (degrees mein, 0-360, jahan 0=right, 90=down) kya hai?',
  'lab.p9_magfields_placeholder': 'masalan 180',
  'lab.p9_magfields_correct': 'Sahi! Field North se South ki taraf ishara karta hai, jo magnet ke bilkul oopar seedhe left (180°) hai.',
  'lab.p9_magfields_incorrect': 'Ghalat. Magnet ke center ke bilkul oopar compass rakh kar dekhein. Arrow kis simt mein hai? (0°=Right, 90°=Down, 180°=Left)',

  // Magnetism Induction Lab
  'lab.p9_magind_theory': 'Unmagnetized steel mein chotay magnetic domains (atoms ke groups) hote hain jo randomly oriented hain. Kyunki yeh har simt mein ishara karte hain, in ke magnetic fields cancel ho jate hain. Stroking: Magnet ko ek hi simt mein steel par bar bar pherna domains ko align karne par majboor karta hai. Hammering: Dhakkan se metal vibrate hota hai, domains ko external field ke saath align hone deta hai.',
  'lab.p9_magind_instructions': '1. Magnet ko steel bar par ek simt se dosri simt tak bar bar ghareet kar domains ko align hote dekhein.\n2. Bar ki orientation badlein aur Hammer Bar dabaye asar dekhne ke liye.',
  'lab.p9_magind_section1': 'Theory aur Siyaq',
  'lab.p9_magind_section2': 'Interactive Simulator',
  'lab.p9_magind_section3': 'Data Logging aur Analysis',
  'lab.p9_magind_ew_label': 'Bar Aligned East-West',
  'lab.p9_magind_ns_label': 'Bar Aligned North-South',
  'lab.p9_magind_hammer_btn': 'Hammer Bar',
  'lab.p9_magind_reset_btn': 'Steel Reset karein',
  'lab.p9_magind_table_action': 'Action',
  'lab.p9_magind_table_magnetization': 'Net Magnetization',
  'lab.p9_magind_no_data': 'Data record karne ke liye simulator se interact karein.',
  'lab.p9_magind_assessment_title': 'Imtihaan',
  'lab.p9_magind_assessment_q': 'Agar aap unmagnetized steel bar ko Left se Right magnet ke North pole se ghaarite hain, to bar ka kaun sa end North pole banta hai (Left ya Right)?',
  'lab.p9_magind_placeholder': 'Left ya Right type karein',
  'lab.p9_magind_guess_left': '',
  'lab.p9_magind_guess_right': '',
  'lab.p9_magind_correct': 'Sahi! Domains ke North poles magnet ke North pole se repel hote hain, akhir me left ki taraf ishara karte hain. Is liye left end North banta hai.',
  'lab.p9_magind_incorrect': 'Ghalat. Left se right stroke karne ke baad red arrows (North poles) ka observe karein. Yeh kis simt mein hain?',

  // Everyday Physics Lab
  'lab.p9_everyday_theory': 'Physics hamari roozmarah ki zindagi mein har cheez par hukumat karti hai! Teen ahem concepts: Free Fall (h = ½gt²), Periodic Motion (T = 2π√(L/g)), aur Kinetic Friction (d = v₀² / (2μg)).',
  'lab.p9_everyday_instructions': 'Shelf height adjust karein, phir ball ko drop karne ke liye click karein. Pendulum length adjust karein, phir bob ko swing karne ke liye click karein. Box ko floor par slide karne ke liye Push click karein.',
  'lab.p9_everyday_section1': 'Kaam kar rahe Concepts',
  'lab.p9_everyday_section2': 'Interactive Classroom',
  'lab.p9_everyday_section3': 'Experiment Data',
  'lab.p9_everyday_concept1': 'Jab object giraaya jata hai, gravity usay taqreeban 9.8 m/s² se accelerate karti hai. Oonchai aur time ka talluq: h = ½gt².',
  'lab.p9_everyday_concept2': 'Pendulum aage peeche jhoolta hai. Ek mukammal jhoolay ka waqt (Period, T) sirf us ki length aur gravity par munsar hai: T = 2π√(L/g).',
  'lab.p9_everyday_concept3': 'Sliding box dheema ho jata hai kyunki floor frictional force lagata hai. Rukne se pehle slide kiya gaya distance initial velocity aur coefficient of friction (μ) par munsar hai: d = v₀² / (2μg).',
  'lab.p9_everyday_gravity_title': 'Gravity ka hisab',
  'lab.p9_everyday_friction_title': 'Friction ka hisab',
  'lab.p9_everyday_gravity_desc': 'Ball giraayein. g = 2h / t² istemal karte hue g (m/s²) calculate karein.',
  'lab.p9_everyday_friction_desc': 'Box push karein. μ = v₀² / (2gd) istemal karte hue μ calculate karein (g=9.8)',
  'lab.p9_everyday_gravity_placeholder': 'g value...',
  'lab.p9_everyday_friction_placeholder': 'μ value...',
  'lab.p9_everyday_check_btn': 'Check',
  'lab.p9_everyday_gravity_correct': 'Sahi! Gravity ki wajah se acceleration taqreeban 9.8 m/s² hai.',
  'lab.p9_everyday_gravity_incorrect': 'Ghalat. g = 2h / t² istemal karna yaad rakhein measure ki hui values ke saath.',
  'lab.p9_everyday_friction_correct': 'Sahi! Coefficient of kinetic friction 0.5 hai.',
  'lab.p9_everyday_friction_incorrect': 'Ghalat. μ = v₀² / (2 × 9.8 × d) istemal karein logs se.',
  'lab.p9_everyday_reset_btn': 'Objects Reset karein',
  'lab.p9_everyday_table_object': 'Object',
  'lab.p9_everyday_table_measurement': 'Measurement',
  'lab.p9_everyday_no_data': 'Data log karne ke liye objects se interact karein.',

