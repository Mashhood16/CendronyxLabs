  // --- P11 Waves ---
  'lab.p11_waves_title': 'Waves',
  'lab.p11_waves_theory_title': 'Wave Properties & Superposition',
  'lab.p11_waves_theory_p1': 'Jab do waves space mein ek hi point par milti hain, to woh superpose hoti hain. Resulting displacement individual displacements ka sum hota hai.',
  'lab.p11_waves_theory_p2': '<strong>Constructive Interference</strong> tab hota hai jab waves in phase hon (path difference = n\u03bb). <strong>Destructive Interference</strong> tab hota hai jab waves out of phase hon (path difference = (n+\u00bd)\u03bb).',
  'lab.p11_waves_instructions': 'Frequency aur phase difference ko adjust karein. Dekhein ke constructive aur destructive interference patterns kaise bante hain.',
