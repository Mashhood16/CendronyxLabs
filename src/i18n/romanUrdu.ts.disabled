  // Half-Life
  'lab.p10_halflife_title': 'Unit 20: Half-Life Simulation',
  'lab.p10_halflife_subtitle': 'Radioactive decay curves ka quantitative analysis.',
  'lab.p10_halflife_theory': 'Radioactive decay ek random process hai. Decay ki sharah active nuclei N ki tadaad ke proportional hai:',
