  // Lorentz Force
  'lab.p10_lorentz_title': "Unit 17: Lorentz Force & DC Motor Principle",
  'lab.p10_lorentz_subtitle': 'Uniform magnetic field mein current-carrying wire par magnetic force naapein.',
  'lab.p10_lorentz_theory1': 'Length L ki wire jo current I carry karti hai magnetic field B mein, magnetic force Fm experience karti hai:',
  'lab.p10_lorentz_formula1': 'Fm = B · I · L',
  'lab.p10_lorentz_theory2': 'Jab wire mass m ke pendulum ki tarah latakti hai, gravity usay neeche khenchti hai. Equilibrium par angle θ:',
  'lab.p10_lorentz_formula2': 'tan(θ) = (B · I · L) / (m · g)',
