  // Electroscope
  'lab.p10_escope_title': 'Unit 15: Gold-Leaf Electroscope',
  'lab.p10_escope_subtitle': 'Induction aur conduction ke zariye electric charge ka pata lagayein.',
  'lab.p10_escope_theory': 'Electroscope charge detect karta hai. Jab charged rod brass disc ke paas laya jata hai, yeh charge separation induce karta hai (<strong>Induction</strong>). Electrons repel ya attract hote hain, gold leaf ko net charge dete hain jo stem se repels karta hai.',
  'lab.p10_escope_induction': 'Agar rod disc ko touch karta hai (<strong>Conduction</strong>), electrons transfer hote hain, electroscope permanently charged ho jata hai.',
  'lab.p10_escope_conduction': 'Deflection angle θ roughly leaf par charge ke square ke proportional hai.',
  'lab.p10_escope_angle': 'Deflection angle θ roughly leaf par charge ke square ke barabar hota hai.',
  'lab.p10_escope_setup': 'Experiment Setup',
  'lab.p10_escope_rod_label': 'Rod Charge (Q_rod)',
  'lab.p10_escope_dist_label': 'Rod Distance (d)',
  'lab.p10_escope_dist_hint': 'd = 0 matlab touch (Conduction).',
  'lab.p10_escope_ground_btn': 'Electroscope Ground karein (Net Charge Reset)',
  'lab.p10_escope_angle_display': 'Deflection Angle θ',
  'lab.p10_escope_data': 'Data Logging',
  'lab.p10_escope_record': 'Record',
  'lab.p10_escope_table_qrod': 'Q_rod (μC)',
  'lab.p10_escope_table_d': 'd (cm)',
  'lab.p10_escope_table_qnet': 'Q_net (μC)',
  'lab.p10_escope_table_angle': 'Angle θ',
  'lab.p10_escope_no_data': 'Abhi tak koi data record nahi.',
  'lab.p10_escope_analysis': 'Analysis Check',
  'lab.p10_escope_q': 'Ek neutral electroscope ko negative charged rod touch karti hai, phir rod hata li jati hai. Ek positive charged rod disc ke paas layi jati hai (baghair touch kiye). Kya leaf angle barhta hai, ghatta hai, ya wahi rehta hai?',
  'lab.p10_escope_hint': 'Kya hota hai electrons ke saath leaf par jab positive rod disc ke paas layi jati hai?',
  'lab.p10_escope_placeholder': 'masalan decrease',
  'lab.p10_escope_correct_fb': 'Sahi! Positive rod electrons ko disc ki taraf khenchti hai, leaf ko kam negative chhorti hai, is liye repulsion (aur angle) ghatta hai.',
  'lab.p10_escope_incorrect_fb': 'Ghalat. Simulation try karein! Electroscope ko negative charge dein, phir positive rod ko paas layein.',
  'lab.p10_escope_qnet_label': 'Q_net: {q} μC',

