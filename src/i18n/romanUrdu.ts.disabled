  // --- P11 Electricity ---
  'lab.p11_elec_title': 'Electricity',
  'lab.p11_elec_theory_title': 'RC Circuits & Time Constants',
  'lab.p11_elec_theory_p1': 'RC circuit ek resistor (R) aur capacitor (C) par mushtamil hota hai. Time constant \u03c4 = RC ye tay karta hai ke capacitor kitni jaldi charge ya discharge hota hai.',
  'lab.p11_elec_theory_p2': '<strong>Charging:</strong> V(t) = V\u2080(1 - e^(-t/\u03c4)). <strong>Discharging:</strong> V(t) = V\u2080 \u00d7 e^(-t/\u03c4).',
  'lab.p11_elec_instructions': 'R aur C ki values adjust karein, phir Start Charging ya Start Discharge dabayein. Capacitor ke voltage ko time ke saath dekhein.',
  'lab.p11_elec_sim_title': 'RC Circuit Simulator',
