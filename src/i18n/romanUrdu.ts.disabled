  // Coulomb's Law
  'lab.p10_coulomb_title': "Unit 15: Coulomb's Law & Electrostatics",
  'lab.p10_coulomb_subtitle': 'Do point charges ke darmiyan electric force ka jaiza lein.',
  'lab.p10_coulomb_theory': "Coulomb's Law kehti hai ke do charged objects ke darmiyan electrical force un par charge ki quantity ke product ke proportional aur separation distance ke square ke inverse proportional hota hai.",
  'lab.p10_coulomb_formula': 'F = k · |q₁q₂| / r²',
  'lab.p10_coulomb_formula_desc': 'Jahan k ≈ 8.99 × 10⁹ N·m²/C² (Coulomb constant). Measurements mein realistic sensor noise (±2%) shamil hai.',
